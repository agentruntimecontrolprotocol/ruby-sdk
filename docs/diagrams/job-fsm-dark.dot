// ============================================================================
//  Arcp::Job FSM (DARK variant)
// ============================================================================

digraph JobFSM {
  rankdir=TB;
  bgcolor="transparent";
  compound=true;
  fontname="TT Commons Pro Trial";
  splines=spline;
  nodesep=0.32;
  ranksep=0.55;
  pad="0.35,0.25";
  labelloc=b;
  label=<<FONT POINT-SIZE="10" COLOR="#94A3B8">Arcp::Job FSM — spec §7 §8 §9 §12</FONT>>;

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#334155",
    color="#475569",
    fontname="TT Commons Pro Trial",
    fontsize=11,
    fontcolor="#F1F5F9",
    margin="0.22,0.11",
    penwidth=1.0
  ];

  edge [
    fontname="TT Commons Pro Trial",
    fontsize=9,
    fontcolor="#94A3B8",
    color="#64748B",
    penwidth=1.1,
    arrowsize=0.75,
    arrowhead=vee
  ];

  submit_sent [
    label=<<FONT POINT-SIZE="12"><B>submit_sent</B></FONT>>,
    fillcolor="#3B82F6", color="#2563EB",
    fontcolor="white", penwidth=1.4
  ];

  accepted [label="accepted"];

  running [
    label=<<FONT POINT-SIZE="12"><B>running</B></FONT>>,
    fillcolor="#F59E0B", color="#D97706",
    fontcolor="white", penwidth=1.4
  ];

  running_sub [label="running_with_subscriber"];

  success [
    label="success",
    shape=doublecircle, fillcolor="#dcfce7", fontcolor="#1F2937"
  ];

  err_cancelled [
    label="error_cancelled",
    shape=doublecircle, fillcolor="#fee2e2", fontcolor="#1F2937"
  ];

  err_timeout [
    label="error_timeout",
    shape=doublecircle, fillcolor="#fee2e2", fontcolor="#1F2937"
  ];

  err_lease [
    label="error_lease_expired",
    shape=doublecircle, fillcolor="#fee2e2", fontcolor="#1F2937"
  ];

  err_budget [
    label="error_budget_exhausted",
    shape=doublecircle, fillcolor="#fee2e2", fontcolor="#1F2937"
  ];

  edge [color="#94A3B8", penwidth=1.2];
  submit_sent -> accepted [label="recv job.accepted (§7.1)"];
  accepted -> running [label="recv job.running (§7.6)"];
  running -> running_sub [label="attach subscriber"];
  running_sub -> running [label="subscriber detach"];
  running -> success [label="recv job.result"];

  edge [color="#475569", penwidth=1.0];
  running -> err_cancelled [label="job.cancel ack"];
  running -> err_timeout [label="deadline_ms exceeded (§9.5)"];
  running -> err_lease [label="lease expired (§9.6)"];
  running -> err_budget [label="budget exhausted (§12)"];
  accepted -> err_cancelled [label="cancel before run"];
  submit_sent -> err_budget [label="job.reject budget"];
}
